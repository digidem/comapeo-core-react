{
	"name": "@comapeo/core-react",
	"version": "11.0.4",
	"description": "React wrapper for working with @comapeo/core",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/digidem/comapeo-core-react.git"
	},
	"keywords": [
		"comapeo"
	],
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/digidem/comapeo-core-react/issues"
	},
	"homepage": "https://github.com/digidem/comapeo-core-react#readme",
	"authors": [
		"Andrew Chou <achou@awana.digital>"
	],
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/esm/index.d.ts",
				"default": "./dist/esm/index.js"
			},
			"require": {
				"types": "./dist/commonjs/index.d.ts",
				"default": "./dist/commonjs/index.js"
			}
		},
		"./package.json": "./package.json"
	},
	"main": "./dist/commonjs/index.js",
	"types": "./dist/commonjs/index.d.ts",
	"module": "./dist/esm/index.js",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "^24",
			"onFail": "warn"
		}
	},
	"files": [
		"dist/",
		"docs/API.md"
	],
	"tshy": {
		"project": "./tsconfig.build.json",
		"selfLink": false,
		"exports": {
			".": "./src/index.ts",
			"./package.json": "./package.json"
		}
	},
	"scripts": {
		"docs:generate": "tsdoc --src=src/contexts/*,src/hooks/* --dest=docs/API.md --noemoji --types",
		"lint:eslint": "eslint --cache .",
		"lint:format": "prettier --cache --check .",
		"lint": "npm-run-all --parallel --continue-on-error --print-label --aggregate-output lint:*",
		"prepack": "tshy",
		"prepare": "husky",
		"test": "vitest run",
		"types": "tsc"
	},
	"dependencies": {
		"@comapeo/map-server": "^1.1.3",
		"ensure-error": "^5.0.0",
		"eventsource-client": "^1.2.0",
		"type-fest": "^5.6.0"
	},
	"peerDependencies": {
		"@comapeo/core": "^7.2.0",
		"@comapeo/ipc": "^8.0.0",
		"@tanstack/react-query": "^5",
		"react": "^18 || ^19"
	},
	"devDependencies": {
		"@comapeo/core": "7.2.0",
		"@comapeo/ipc": "8.0.0",
		"@eslint/compat": "2.1.0",
		"@eslint/js": "10.0.1",
		"@ianvs/prettier-plugin-sort-imports": "4.7.1",
		"@mapeo/crypto": "1.1.0",
		"@mapeo/default-config": "6.0.0",
		"@mapeo/mock-data": "5.0.0",
		"@tanstack/eslint-plugin-query": "5.100.11",
		"@tanstack/react-query": "5.100.11",
		"@testing-library/dom": "10.4.1",
		"@testing-library/react": "16.3.2",
		"@types/jsdom": "28.0.3",
		"@types/node": "24.12.4",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitest/eslint-plugin": "1.6.17",
		"eslint": "10.4.0",
		"eslint-plugin-react-hooks": "7.1.1",
		"eslint-plugin-testing-library": "7.16.2",
		"fastify": "4.29.1",
		"globals": "17.6.0",
		"husky": "9.1.7",
		"jsdom": "29.1.1",
		"ky": "1.14.3",
		"lint-staged": "17.0.5",
		"npm-run-all2": "8.0.4",
		"prettier": "3.8.3",
		"random-access-memory": "6.2.1",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"secret-stream-http": "1.0.1",
		"tsdoc-markdown": "1.5.0",
		"tshy": "3.3.2",
		"typescript": "5.9.3",
		"typescript-eslint": "8.59.4",
		"uint8array-extras": "1.5.0",
		"vitest": "4.1.6"
	}
}
